# BSL Atlas configuration
# Copy to .env and fill in your values

# =============================================================================
# PATH TO YOUR 1C SOURCE CODE (required)
# =============================================================================
# Export from 1C Configurator: Configuration -> Dump configuration to files
# Point SOURCE_PATH to the root of your exported config or extension sources
# Supports any layout: cf/ subdirectory, flat structure, or cfe/ extensions
# Docker bind-mount from SOURCE_PATH to /data/source is mandatory for real indexing
# On Windows, prefer an ASCII-only alias path if the real path contains spaces or Cyrillic
SOURCE_PATH=./source

# ChromaDB vector index storage
CHROMA_PATH=./chroma_db

# =============================================================================
# EMBEDDING PROVIDERS
# =============================================================================
# Three separate providers let you optimize cost vs speed:
#
#   INDEXING_PROVIDER  - used once for initial ChromaDB bulk fill
#   SEARCH_PROVIDER    - used for every semantic search query
#   REINDEX_PROVIDER   - used when you manually call reindex after code changes
#
# Simple setup:
INDEXING_PROVIDER=openrouter
SEARCH_PROVIDER=openrouter
REINDEX_PROVIDER=openrouter
#
# Hybrid setup example:
# INDEXING_PROVIDER=openrouter
# SEARCH_PROVIDER=ollama
# REINDEX_PROVIDER=ollama

# =============================================================================
# API KEYS
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# OLLAMA (optional, for hybrid setup)
# =============================================================================
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3-embedding:4b

# =============================================================================
# INDEXING MODE
# =============================================================================
# fast - SQLite only. No API key needed. Structural search works immediately.
# full - SQLite + ChromaDB vectors. Requires embedding provider and API key.
INDEXING_MODE=fast

# =============================================================================
# INDEXING SETTINGS
# =============================================================================
AUTO_INDEX=true
CHROMADB_AUTO_INDEX=false
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
EMBEDDING_CONCURRENCY=5
EMBEDDING_BATCH_SIZE=10

# =============================================================================
# SERVER
# =============================================================================
MCP_PORT=8000
